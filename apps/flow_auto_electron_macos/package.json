{
  "name": "flow-auto-veo-electron",
  "version": "2.0.0-modern-ui",
  "private": true,
  "description": "FLOW AUTO VEO 3 Modern UI - Electron React Tailwind",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "autoprefixer": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "concurrently": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "lucide-react": "latest",
    "postcss": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "latest",
    "tailwindcss": "^3.4.17",
    "typescript": "latest",
    "vite": "latest",
    "wait-on": "latest"
  },
  "build": {
    "directories": {
      "output": "release"
    },
    "appId": "com.flowauto.veo3.modern",
    "productName": "FLOW AUTO VEO 3 Modern",
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "payload",
        "to": "payload"
      },
      {
        "from": "public/assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "public/assets/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "FlowAutoElectron-macOS.dmg",
      "x64ArchFiles": "**/payload/python/runtime/lib/python3.11/site-packages/playwright/driver/node, **/node_modules/@ffmpeg-installer/**"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/assets/icon.png",
      "artifactName": "FlowAutoElectron-Linux.AppImage"
    },
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**"
    ],
    "portable": {
      "artifactName": "FlowAutoElectron-Windows.exe"
    }
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0"
  }
}
